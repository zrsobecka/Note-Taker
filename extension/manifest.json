{
  "manifest_version": 3,
  "name": "Chrome Note Clipper",
  "description": "Turn selected or copied text into clean Obsidian notes with a local LM Studio model.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Note Clipper"
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "clipboardRead",
    "nativeMessaging",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:1234/*",
    "http://127.0.0.1:1234/*"
  ]
}

