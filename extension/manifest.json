{
  "manifest_version": 3,
  "name": "Obsidian Note Taker",
  "description": "Turn selected or copied text into clean Obsidian notes with a local LM Studio model.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Obsidian Note Taker"
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "clipboardRead",
    "nativeMessaging",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:1234/*",
    "http://127.0.0.1:1234/*"
  ]
}
